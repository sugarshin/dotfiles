{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_TASKS": "true",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_TRACES_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_METRICS_INCLUDE_SESSION_ID": "1",
    "OTEL_METRICS_INCLUDE_VERSION": "1",
    "OTEL_METRICS_INCLUDE_ACCOUNT_UUID": "1",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA": "1"
  },
  "permissions": {
    "deny": [
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/dispatch.sh SessionStart"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/dispatch.sh Stop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.ts"
  },
  "enabledPlugins": {
    "dinii-kpi@dinii-tools": true,
    "my-insights@dinii-tools": true,
    "deep-plan@dinii-tools": true,
    "dinii-color@dinii-tools": true,
    "bakuraku-expense@dinii-tools": true,
    "figma@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "dinii-conventions@dinii-tools": true,
    "tech-article-writer@dinii-tools": true,
    "persona-analyzer@dinii-tools": true,
    "slack-post-generator@dinii-tools": true,
    "superpowers@claude-plugins-official": false,
    "sentry@claude-plugins-official": true,
    "member-lookup@dinii-tools": true,
    "playwright@claude-plugins-official": true,
    "daily-report@dinii-tools": true,
    "quarterly-self-eval@dinii-tools": true,
    "plugin-dev@claude-plugins-official": true,
    "sugarshin-tools-private@sugarshin-marketplace-private": true,
    "engineering-knowledge@dinii-tools": true,
    "internal-tools@dinii-tools": true,
    "knowledgebase@dinii-tools": true,
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "neon@claude-plugins-official": true,
    "onboarding@dinii-tools": true,
    "notion@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-skills": {
      "source": {
        "source": "github",
        "repo": "alirezarezvani/claude-skills"
      }
    },
    "sugarshin-marketplace-private": {
      "source": {
        "source": "github",
        "repo": "sugarshin/claude-plugins-sugarshin-private"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "minimumVersion": "2.1.91",
  "skipDangerousModePermissionPrompt": true,
  "terminalProgressBarEnabled": false,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754044074934
  }
}
