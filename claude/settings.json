{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_TASKS": "true",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf"
  },
  "permissions": {
    "deny": [
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/review-agent/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/review-agent/hooks/stop.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "dinii-kpi@dinii-tools": true,
    "my-insights@dinii-tools": true,
    "customer-insights@dinii-tools": true,
    "deep-plan@dinii-tools": true,
    "dinii-color@dinii-tools": true,
    "engineering-knowledge@dinii-tools": true,
    "bakuraku-expense@dinii-tools": true,
    "figma@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "dinii-conventions@dinii-tools": true,
    "tech-article-writer@dinii-tools": true,
    "notion-docs@dinii-tools": true,
    "persona-analyzer@dinii-tools": true,
    "slack-post-generator@dinii-tools": true,
    "superpowers@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "statusline-reporter@dinii-tools": true,
    "member-lookup@dinii-tools": true,
    "playwright@claude-plugins-official": true,
    "daily-report@dinii-tools": true,
    "quarterly-self-eval@dinii-tools": true
  },
  "extraKnownMarketplaces": {
    "claude-code-skills": {
      "source": {
        "source": "github",
        "repo": "alirezarezvani/claude-skills"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.81",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754044074934
  }
}
